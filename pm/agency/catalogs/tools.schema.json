{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agency tools catalog",
  "type": "object",
  "required": ["version", "updated", "items"],
  "properties": {
    "version": { "type": "string" },
    "updated": { "type": "string" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "category", "license", "kind", "urls", "status"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "category": {
            "type": "string",
            "enum": [
              "photo",
              "video",
              "motion",
              "3d",
              "graphics",
              "layout",
              "ui",
              "charting",
              "social",
              "docs",
              "audio",
              "ai-media",
              "asset-management",
              "fonts",
              "icons",
              "other"
            ]
          },
          "kind": { "type": "string", "enum": ["oss", "commercial", "hybrid"] },
          "license": { "type": "string" },
          "status": { "type": "string", "enum": ["recommended", "allowed", "avoid", "deprecated"] },
          "why": { "type": "string" },
          "bestFor": { "type": "array", "items": { "type": "string" } },
          "tradeoffs": { "type": "array", "items": { "type": "string" } },
          "urls": {
            "type": "object",
            "required": ["homepage"],
            "properties": {
              "homepage": { "type": "string" },
              "repo": { "type": "string" },
              "docs": { "type": "string" }
            },
            "additionalProperties": false
          },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}

