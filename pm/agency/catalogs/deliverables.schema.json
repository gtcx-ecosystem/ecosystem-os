{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agency campaign deliverables catalog",
  "type": "object",
  "required": ["version", "updated", "items"],
  "properties": {
    "version": { "type": "string" },
    "updated": { "type": "string" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "campaignId", "type", "path", "status", "license"],
        "properties": {
          "id": { "type": "string" },
          "campaignId": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["one-pager", "slide-deck", "script", "social-kit", "internal-sheet"]
          },
          "path": { "type": "string" },
          "status": { "type": "string", "enum": ["draft", "review", "current", "deprecated"] },
          "license": { "type": "string" },
          "claimWitnessMap": { "type": "string" },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
