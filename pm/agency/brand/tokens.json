{
  "$schema": "gtcx://ecosystem-os/agency-brand-tokens/v1",
  "version": "0.1.0",
  "updated": "2026-06-17",
  "brand": "gtcx",
  "colors": {
    "primary": {
      "900": "#0B1A2B",
      "800": "#12263D",
      "700": "#1A3550",
      "600": "#234563",
      "500": "#2D5678"
    },
    "accent": {
      "gold": "#C9A227",
      "goldMuted": "#A8841F",
      "copper": "#B87333"
    },
    "neutral": {
      "0": "#FFFFFF",
      "50": "#F7F8FA",
      "100": "#EEF1F5",
      "200": "#D8DEE6",
      "500": "#6B7A8C",
      "700": "#3D4A59",
      "900": "#1A2330"
    },
    "semantic": {
      "success": "#1F7A4D",
      "warning": "#B8860B",
      "error": "#B42318",
      "info": "#2563EB"
    }
  },
  "typography": {
    "fontFamilies": {
      "display": "Instrument Serif, Georgia, serif",
      "body": "IBM Plex Sans, system-ui, sans-serif",
      "mono": "IBM Plex Mono, ui-monospace, monospace"
    },
    "scale": {
      "xs": "0.75rem",
      "sm": "0.875rem",
      "base": "1rem",
      "lg": "1.125rem",
      "xl": "1.25rem",
      "2xl": "1.5rem",
      "3xl": "1.875rem",
      "4xl": "2.25rem",
      "5xl": "3rem"
    },
    "lineHeight": {
      "tight": 1.2,
      "normal": 1.5,
      "relaxed": 1.65
    },
    "weight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    }
  },
  "spacing": {
    "unit": 4,
    "scale": {
      "0": "0",
      "1": "4px",
      "2": "8px",
      "3": "12px",
      "4": "16px",
      "6": "24px",
      "8": "32px",
      "12": "48px",
      "16": "64px"
    }
  },
  "layout": {
    "gridColumns": 12,
    "maxContentWidth": "1120px",
    "slideAspect": "16:9",
    "onePagerSize": "A4"
  },
  "voice": {
    "tone": "institutional",
    "register": "precise",
    "forbidden": ["hype", "vague superlatives", "unwitnessed claims"]
  },
  "export": {
    "formats": ["pdf", "pptx", "png", "webp", "md"],
    "naming": "{campaignId}-{assetType}-v{semver}"
  }
}
