{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gtcx://ecosystem-os/kaleidoscope-ai/mpr-relation-gap.schema/v1",
  "title": "Kaleidoscope AI MPR relation gap witness",
  "type": "object",
  "required": [
    "schema",
    "generatedAt",
    "repo",
    "ok",
    "summary",
    "gaps",
    "approval",
    "sources"
  ],
  "properties": {
    "schema": { "const": "gtcx://ecosystem-os/kaleidoscope-ai/mpr-relation-gap/v1" },
    "generatedAt": { "type": "string" },
    "repo": { "const": "ecosystem-os" },
    "ok": { "type": "boolean" },
    "summary": {
      "type": "object",
      "required": ["gapCount", "targetRepos", "scoreChangeAllowed"],
      "additionalProperties": true
    },
    "gaps": {
      "type": "array",
      "items": { "$ref": "#/$defs/gap" }
    },
    "approval": {
      "type": "object",
      "required": ["status", "required", "reason"],
      "properties": {
        "status": { "enum": ["draft_pending_approval", "approved", "rejected"] },
        "required": { "type": "boolean" },
        "reason": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "sources": {
      "type": "object",
      "required": ["signalFleet", "observatory", "executionStudio"]
    }
  },
  "$defs": {
    "gap": {
      "type": "object",
      "required": [
        "repo",
        "currentSignalELevel",
        "currentMprRelation",
        "recommendedResolution",
        "scoreChangeAllowed",
        "validation"
      ],
      "properties": {
        "repo": { "type": "string", "minLength": 1 },
        "currentSignalELevel": { "type": "string", "minLength": 1 },
        "currentMprRelation": { "type": "string", "minLength": 1 },
        "recommendedResolution": { "type": "string", "minLength": 1 },
        "scoreChangeAllowed": { "type": "boolean" },
        "validation": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
