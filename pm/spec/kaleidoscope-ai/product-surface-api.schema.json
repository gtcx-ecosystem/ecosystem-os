{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gtcx://ecosystem-os/kaleidoscope-ai/product-surface-api.schema/v1",
  "title": "Kaleidoscope AI product surface API contract",
  "type": "object",
  "required": [
    "schema",
    "resource",
    "generatedAt",
    "mode",
    "decision",
    "freshness",
    "citations",
    "approval",
    "witnesses"
  ],
  "properties": {
    "schema": { "const": "gtcx://ecosystem-os/kaleidoscope-ai/product-surface-api/v1" },
    "resource": {
      "enum": [
        "fleet",
        "graph",
        "query",
        "decision-room",
        "signal",
        "actions",
        "partner-room",
        "release",
        "phase-2"
      ]
    },
    "generatedAt": { "type": "string", "format": "date-time" },
    "mode": {
      "enum": ["read", "draft", "write-request", "external-request"]
    },
    "decision": { "type": "string", "minLength": 1 },
    "confidence": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 1
    },
    "freshness": {
      "type": "object",
      "required": ["status", "sourceDates"],
      "properties": {
        "status": { "enum": ["fresh", "mixed", "stale", "unknown"] },
        "sourceDates": {
          "type": "array",
          "items": { "$ref": "#/$defs/sourceDate" }
        }
      },
      "additionalProperties": true
    },
    "citations": {
      "type": "array",
      "items": { "$ref": "#/$defs/citation" }
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "unsupportedClaims": {
      "type": "array",
      "items": { "type": "string" }
    },
    "approval": {
      "type": "object",
      "required": ["status", "boundary"],
      "properties": {
        "status": {
          "enum": [
            "not_required",
            "draft_pending_approval",
            "blocked_until_explicit_approval",
            "approved"
          ]
        },
        "boundary": {
          "enum": ["read", "draft", "write", "external"]
        },
        "reason": { "type": "string" },
        "approvalRecord": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "nextActions": {
      "type": "array",
      "items": { "$ref": "#/$defs/action" }
    },
    "witnesses": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "sourceDate": {
      "type": "object",
      "required": ["path", "sourceDate"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sourceDate": { "type": "string" }
      },
      "additionalProperties": true
    },
    "citation": {
      "type": "object",
      "required": ["path", "reason"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "sourceDate": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "action": {
      "type": "object",
      "required": ["id", "ownerRepo", "status", "validation"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "ownerRepo": { "type": "string", "minLength": 1 },
        "status": {
          "enum": ["draft", "approval_required", "approved", "blocked", "complete"]
        },
        "validation": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
