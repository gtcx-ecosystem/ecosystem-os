{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gtcx://ecosystem-os/kaleidoscope-ai/mcp-config.schema/v1",
  "title": "Kaleidoscope AI MCP config",
  "type": "object",
  "required": ["$schema", "repo", "mode", "server", "tools", "permissions", "humanApprovalRequired"],
  "properties": {
    "$schema": { "const": "gtcx://ecosystem-os/mcp-config/v1" },
    "repo": { "type": "string", "minLength": 1 },
    "mode": { "enum": ["hub", "consumer", "disabled", "exception"] },
    "server": { "type": "string", "minLength": 1 },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "permissionClass"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "permissionClass": { "enum": ["read", "write", "approval", "external"] },
          "description": { "type": "string" }
        }
      }
    },
    "permissions": { "type": "array", "items": { "type": "string" } },
    "humanApprovalRequired": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
