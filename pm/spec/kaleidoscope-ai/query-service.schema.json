{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gtcx://ecosystem-os/kaleidoscope-ai/query-service.schema/v1",
  "title": "Kaleidoscope AI unified query service witness",
  "type": "object",
  "required": [
    "schema",
    "generatedAt",
    "repo",
    "phase",
    "ok",
    "summary",
    "queries",
    "issues"
  ],
  "properties": {
    "schema": { "const": "gtcx://ecosystem-os/kaleidoscope-ai/query-service/v1" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "repo": { "const": "ecosystem-os" },
    "phase": { "type": "string", "minLength": 1 },
    "ok": { "type": "boolean" },
    "summary": {
      "type": "object",
      "required": ["queryCount", "passedQueries", "failedQueries", "averageConfidence"],
      "properties": {
        "queryCount": { "type": "integer", "minimum": 0 },
        "passedQueries": { "type": "integer", "minimum": 0 },
        "failedQueries": { "type": "integer", "minimum": 0 },
        "averageConfidence": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": true
    },
    "queries": {
      "type": "array",
      "items": { "$ref": "#/$defs/queryResult" }
    },
    "issues": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "queryResult": {
      "type": "object",
      "required": [
        "id",
        "query",
        "route",
        "answer",
        "confidence",
        "citations",
        "freshness",
        "ok",
        "issues"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "query": { "type": "string", "minLength": 1 },
        "route": { "enum": ["graph", "rag", "lexical", "hybrid"] },
        "routeReason": { "type": "string" },
        "answer": { "type": "string", "minLength": 1 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "citations": {
          "type": "array",
          "items": { "$ref": "#/$defs/citation" }
        },
        "freshness": {
          "type": "object",
          "required": ["sourceDateCount", "oldestSourceDate", "newestSourceDate"],
          "properties": {
            "sourceDateCount": { "type": "integer", "minimum": 0 },
            "oldestSourceDate": { "type": ["string", "null"] },
            "newestSourceDate": { "type": ["string", "null"] }
          },
          "additionalProperties": true
        },
        "retrieval": {
          "type": "object",
          "additionalProperties": true
        },
        "ok": { "type": "boolean" },
        "issues": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "citation": {
      "type": "object",
      "required": ["repo", "path", "sourceDate", "reason"],
      "properties": {
        "repo": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "nodeId": { "type": ["string", "null"] },
        "sourceDate": { "type": ["string", "null"] },
        "reason": { "type": "string", "minLength": 1 },
        "excerpt": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
