{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gtcx://ecosystem-os/kaleidoscope-ai/85-uplift-action.schema/v1",
  "title": "Kaleidoscope AI 8.5 uplift action",
  "type": "object",
  "required": [
    "schema",
    "id",
    "title",
    "status",
    "ownerRepo",
    "targetRepos",
    "priority",
    "currentReadinessScore100",
    "targetReadinessScore100",
    "gapCategory",
    "outcome",
    "evidence",
    "workPlan",
    "validationGate",
    "approvalRequest",
    "releaseGate",
    "acceptanceCriteria"
  ],
  "properties": {
    "schema": { "const": "gtcx://ecosystem-os/kaleidoscope-ai/85-uplift-action/v1" },
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "status": { "enum": ["draft", "approved", "in-progress", "blocked", "done"] },
    "ownerRepo": { "type": "string", "minLength": 1 },
    "targetRepos": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "priority": { "enum": ["P0", "P1", "P2", "P3"] },
    "currentReadinessScore100": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
    "targetReadinessScore100": { "const": 85 },
    "gapCategory": {
      "enum": [
        "agentic-maturity",
        "graph-rag-mcp",
        "mpr",
        "movement-history",
        "qa-testing",
        "deployment",
        "documentation",
        "market-readiness",
        "partner-readiness",
        "security-compliance"
      ]
    },
    "outcome": { "type": "string", "minLength": 1 },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/evidenceRef" }
    },
    "workPlan": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/workStep" }
    },
    "validationGate": { "$ref": "#/$defs/validationGate" },
    "approvalRequest": { "$ref": "#/$defs/approvalRequest" },
    "releaseGate": { "$ref": "#/$defs/releaseGate" },
    "acceptanceCriteria": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "evidenceRef": {
      "type": "object",
      "required": ["path", "reason"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "sourceDate": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "workStep": {
      "type": "object",
      "required": ["step", "ownerRepo", "expectedArtifact"],
      "properties": {
        "step": { "type": "string", "minLength": 1 },
        "ownerRepo": { "type": "string", "minLength": 1 },
        "expectedArtifact": { "type": "string", "minLength": 1 },
        "validationCommand": { "type": "string" }
      },
      "additionalProperties": true
    },
    "validationGate": {
      "type": "object",
      "required": ["command", "successCriteria"],
      "properties": {
        "command": { "type": "string", "minLength": 1 },
        "successCriteria": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "approvalRequest": {
      "type": "object",
      "required": ["status", "required", "boundary", "reason"],
      "properties": {
        "status": { "enum": ["not-required", "draft_pending_approval", "approved", "rejected"] },
        "required": { "type": "boolean" },
        "boundary": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "releaseGate": {
      "type": "object",
      "required": ["status", "criteria"],
      "properties": {
        "status": { "enum": ["blocked", "candidate", "passed"] },
        "criteria": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
