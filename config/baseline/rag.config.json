{
  "$schema": "gtcx://ecosystem-os/rag-config/v1",
  "repo": "ecosystem-os",
  "topology": "hub",
  "knowledge": [
    "docs/business/research/kaleidoscope-ai/",
    "audit/evidence/",
    "audit/independent/"
  ],
  "include": [
    "docs/**/*.md",
    "pm/**/*.json",
    "audit/evidence/*.json",
    "audit/independent/**/*.md"
  ],
  "exclude": [
    "node_modules/**",
    ".git/**",
    ".worktrees/**",
    "audit/archive/**",
    "reports/**"
  ],
  "paths": {
    "index": ".baseline/index",
    "checkpoints": ".baseline/checkpoints"
  },
  "eval": {
    "golden": "config/baseline/rag-eval-golden.json",
    "mockCorpus": "config/baseline/rag-eval-mock-corpus.json"
  }
}
