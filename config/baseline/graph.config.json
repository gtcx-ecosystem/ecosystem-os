{
  "$schema": "gtcx://ecosystem-os/graph-config/v1",
  "repo": "ecosystem-os",
  "entities": [
    {
      "type": "repo",
      "source": "../*/package.json"
    },
    {
      "type": "evidence",
      "source": "../*/audit/evidence/*.json"
    },
    {
      "type": "audit",
      "source": "../*/audit/independent/**/*.md"
    },
    {
      "type": "spec",
      "source": "../*/pm/spec/**/*.json"
    }
  ],
  "relations": [
    {
      "type": "owns",
      "source": "pm/product/prd-index.json"
    },
    {
      "type": "validated_by",
      "source": "audit/evidence/*.json"
    },
    {
      "type": "depends_on",
      "source": "package.json"
    }
  ],
  "evidencePaths": [
    "audit/evidence/kaleidoscope-graph-rag-mcp-latest.json",
    "audit/evidence/signal-fleet-latest.json"
  ],
  "exclude": [
    ".git/**",
    ".worktrees/**",
    "node_modules/**",
    "audit/archive/**"
  ]
}
