{
  "$schema": "gtcx://ecosystem-os/mcp-config/v1",
  "repo": "ecosystem-os",
  "mode": "consumer",
  "server": "baseline-os",
  "tools": [
    {
      "id": "ecosystem.graph.scan",
      "permissionClass": "read",
      "description": "Read-only scan of repo Graph/RAG/MCP readiness and evidence."
    },
    {
      "id": "ecosystem.graph.write-witness",
      "permissionClass": "write",
      "description": "Write local ecosystem-os audit evidence for Kaleidoscope fleet readiness."
    }
  ],
  "permissions": [
    "read:repo-files",
    "write:audit-evidence"
  ],
  "humanApprovalRequired": [
    "write:sibling-repos",
    "external-network",
    "deploy"
  ]
}
