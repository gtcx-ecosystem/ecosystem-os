{
  "$schema": "gtcx://ecosystem-os/eval-config/v1",
  "repo": "ecosystem-os",
  "goldenSets": [
    "config/baseline/rag-eval-golden.json"
  ],
  "qualityGates": [
    {
      "id": "graph-coverage",
      "threshold": 0.85
    },
    {
      "id": "evidence-grounding",
      "threshold": 0.9
    },
    {
