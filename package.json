{
  "name": "ecosystem-os",
  "version": "0.1.0",
  "private": true,
  "description": "Ecosystem OS — fleet documentation, GitBook, GTM, onboarding, and publish registry",
  "repository": {
    "type": "git",
    "url": "https://github.com/gtcx-ecosystem/ecosystem-os.git"
  },
  "license": "MIT",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.18.0",
    "pnpm": ">=9.15.0"
  },
  "type": "module",
  "scripts": {
    "ops:check": "node platform/scripts/ops-check.mjs",
    "test": "node --test platform/scripts/ops-check.test.mjs",
    "test:smoke": "pnpm test",
    "session": "node ../baseline-os/platform/packages/baselineos/dist/cli/bin.js session",
    "next": "node ../baseline-os/platform/scripts/ecosystem/work-next.mjs",
    "gates": "node ../baseline-os/platform/scripts/ecosystem/human-gates-check.mjs",
    "hub": "node ../baseline-os/platform/scripts/ecosystem/hub-sync.mjs",
    "mcp": "node ../baseline-os/platform/packages/baselineos/dist/cli/bin.js serve --mcp-only",
    "serve": "node ../baseline-os/platform/packages/baselineos/dist/cli/bin.js serve --port 3141",
    "agent:start": "node platform/scripts/agent-start.mjs",
    "agent:consumption:check": "node platform/scripts/check-agent-consumption.mjs",
    "agent:reconcile-auto-dev": "node platform/scripts/workspace/hub-reconcile.mjs",
    "agent:next-work": "node platform/scripts/agent-next-work.mjs",
