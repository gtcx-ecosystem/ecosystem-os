{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agency resources catalog",
  "type": "object",
  "required": ["version", "updated", "items"],
  "properties": {
    "version": { "type": "string" },
    "updated": { "type": "string" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "kind", "topics", "urls", "status"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "kind": { "type": "string", "enum": ["website", "github", "article", "library"] },
          "topics": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "license": { "type": "string" },
          "status": { "type": "string", "enum": ["recommended", "allowed", "avoid", "deprecated"] },
          "urls": {
            "type": "object",
            "required": ["primary"],
            "properties": {
              "primary": { "type": "string" },
              "secondary": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": false
          },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}

