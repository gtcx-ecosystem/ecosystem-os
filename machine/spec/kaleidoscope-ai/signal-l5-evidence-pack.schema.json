{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gtcx://ecosystem-os/kaleidoscope-ai/signal-l5-evidence-pack.schema/v1",
  "title": "Kaleidoscope AI SIGNAL L5 evidence pack",
  "type": "object",
  "required": [
    "schema",
    "generatedAt",
    "repo",
    "scope",
    "moduleId",
    "signalAxis",
    "requestedLevel",
    "ok",
    "operatingCycle",
    "summary",
    "selfImprovementEvidence",
    "generativeDesignEvidence",
    "policySynthesisEvidence",
    "crossModuleLearningEvidence",
    "autonomousExperimentationEvidence",
    "humanOverrideEvidence",
    "releaseGate"
  ],
  "properties": {
    "schema": { "const": "gtcx://ecosystem-os/kaleidoscope-ai/signal-l5-evidence-pack/v1" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "repo": { "type": "string", "minLength": 1 },
    "scope": { "const": "product" },
    "moduleId": { "type": "string", "minLength": 1 },
    "signalAxis": { "enum": ["SIGNAL-E", "SIGNAL-P"] },
    "requestedLevel": { "const": "L5" },
    "ok": { "type": "boolean" },
    "operatingCycle": {
      "type": "object",
      "required": ["consecutivePasses", "minimumRequired", "humanOverrideExercised"],
      "properties": {
        "consecutivePasses": { "type": "integer", "minimum": 5 },
        "minimumRequired": { "type": "integer", "minimum": 5 },
        "humanOverrideExercised": { "const": true },
        "cycleWindow": { "type": "string" }
      },
      "additionalProperties": true
    },
    "summary": {
      "type": "object",
      "required": [
        "selfImprovementEvidencePresent",
        "generativeDesignEvidencePresent",
        "policySynthesisEvidencePresent",
        "crossModuleLearningEvidencePresent",
        "autonomousExperimentationEvidencePresent",
        "humanOverrideEvidencePresent"
      ],
      "additionalProperties": true
    },
    "selfImprovementEvidence": { "$ref": "#/$defs/evidenceSet" },
    "generativeDesignEvidence": { "$ref": "#/$defs/evidenceSet" },
    "policySynthesisEvidence": { "$ref": "#/$defs/evidenceSet" },
    "crossModuleLearningEvidence": { "$ref": "#/$defs/evidenceSet" },
    "autonomousExperimentationEvidence": { "$ref": "#/$defs/evidenceSet" },
    "humanOverrideEvidence": { "$ref": "#/$defs/evidenceSet" },
    "releaseGate": {
      "type": "object",
      "required": ["status", "blockingCriteria", "validationCommands", "approvalRequired"],
      "properties": {
        "status": { "enum": ["blocked", "candidate", "approved"] },
        "blockingCriteria": {
          "type": "array",
          "items": { "type": "string" }
        },
        "validationCommands": {
          "type": "array",
          "items": { "type": "string" }
        },
        "approvalRequired": { "type": "boolean" }
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "evidenceRef": {
      "type": "object",
      "required": ["path", "kind", "description"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "kind": {
          "enum": [
            "command-output",
            "trace",
            "policy",
            "approval",
            "eval",
            "rollback",
            "learning-loop",
            "operating-cycle",
            "policy-synthesis",
            "self-improvement",
            "generative-design",
            "cross-module-learning",
            "autonomous-experiment",
            "human-override",
            "witness"
          ]
        },
        "description": { "type": "string", "minLength": 1 },
        "owner": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "additionalProperties": true
    },
    "evidenceSet": {
      "type": "object",
      "required": ["present", "minimumCount", "items", "gaps"],
      "properties": {
        "present": { "type": "boolean" },
        "minimumCount": { "type": "integer", "minimum": 1 },
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidenceRef" }
        },
        "gaps": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
