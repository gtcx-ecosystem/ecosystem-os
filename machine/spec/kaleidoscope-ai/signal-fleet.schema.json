{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gtcx://ecosystem-os/kaleidoscope-ai/signal-fleet.schema/v1",
  "title": "Kaleidoscope AI SIGNAL fleet witness",
  "type": "object",
  "required": [
    "schema",
    "scope",
    "ok",
    "evaluatedAt",
    "date",
    "repoCount",
    "summary",
    "results",
    "issues",
    "sources"
  ],
  "properties": {
    "schema": { "const": "gtcx://ecosystem-os/kaleidoscope-ai/signal-fleet/v1" },
    "scope": { "const": "fleet" },
    "ok": { "type": "boolean" },
    "evaluatedAt": { "type": "string", "format": "date-time" },
    "date": { "type": "string" },
    "repoCount": { "type": "integer", "minimum": 0 },
    "summary": {
      "type": "object",
      "required": [
        "repoCount",
        "generatedRepoWitnesses",
        "notEnoughEvidenceWitnesses",
        "averageOverallScore100",
        "averageSignalPScore100",
        "averageSignalEScore100",
        "overallLevelCounts",
        "signalPLevelCounts",
        "signalELevelCounts",
        "graphRagMcpReadyRepos",
        "mprRelationAvailableRepos"
      ],
      "additionalProperties": true
    },
    "results": {
      "type": "array",
      "items": { "$ref": "#/$defs/repoResult" }
    },
    "issues": {
      "type": "array",
      "items": { "type": "string" }
    },
    "sources": {
      "type": "object",
      "required": ["graphSnapshot", "mprRepo", "frameworkPlan"]
    }
  },
  "$defs": {
    "axis": {
      "type": "object",
      "required": ["level", "score100", "lowestDimension", "published", "summary"],
      "properties": {
        "level": { "enum": ["L0", "L1", "L2", "L3", "L4", "L5"] },
        "score100": { "type": "number", "minimum": 0, "maximum": 100 },
        "lowestDimension": { "type": "string", "minLength": 1 },
        "published": { "type": "boolean" },
        "summary": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "dimension": {
      "type": "object",
      "required": ["level", "score100", "evidence", "gaps"],
      "properties": {
        "level": { "enum": ["L0", "L1", "L2", "L3", "L4", "L5"] },
        "score100": { "type": "number", "minimum": 0, "maximum": 100 },
        "evidence": {
          "type": "array",
          "items": { "type": "string" }
        },
        "gaps": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "repoResult": {
      "type": "object",
      "required": [
        "repo",
        "scope",
        "witnessStatus",
        "signalP",
        "signalE",
        "overallLevel",
        "overallScore100",
        "dimensions",
        "graphRagMcp",
        "mprRelation",
        "bottlenecks",
        "nextUnlocks",
        "evidenceGaps"
      ],
      "properties": {
        "repo": { "type": "string", "minLength": 1 },
        "scope": { "const": "repo" },
        "witnessStatus": { "enum": ["generated", "not-enough-evidence"] },
        "signalP": { "$ref": "#/$defs/axis" },
        "signalE": { "$ref": "#/$defs/axis" },
        "overallLevel": { "enum": ["L0", "L1", "L2", "L3", "L4", "L5"] },
        "overallScore100": { "type": "number", "minimum": 0, "maximum": 100 },
        "dimensions": {
          "type": "object",
          "required": ["signalP", "signalE"],
          "properties": {
            "signalP": {
              "type": "object",
              "additionalProperties": { "$ref": "#/$defs/dimension" }
            },
            "signalE": {
              "type": "object",
              "additionalProperties": { "$ref": "#/$defs/dimension" }
            }
          },
          "additionalProperties": true
        },
        "graphRagMcp": {
          "type": "object",
          "required": ["state", "signalELevelCeiling", "witnesses", "notes"]
        },
        "mprRelation": {
          "type": "object",
          "required": ["available", "source", "composite100", "agenticEmpowerment100", "relation"]
        },
        "bottlenecks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "nextUnlocks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "evidenceGaps": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
