{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gtcx://ecosystem-os/kaleidoscope-ai/graph-snapshot.schema/v1",
  "title": "Kaleidoscope AI graph snapshot witness",
  "type": "object",
  "required": [
    "schema",
    "generatedAt",
    "repo",
    "phase",
    "ok",
    "summary",
    "nodes",
    "edges",
    "aliases",
    "issues"
  ],
  "properties": {
    "schema": { "const": "gtcx://ecosystem-os/kaleidoscope-ai/graph-snapshot/v1" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "repo": { "const": "ecosystem-os" },
    "phase": { "type": "string", "minLength": 1 },
    "ok": { "type": "boolean" },
    "summary": {
      "type": "object",
      "required": [
        "repoCount",
        "presentRepos",
        "missingRepos",
        "nodeCount",
        "edgeCount",
        "aliasCount",
        "configNodeCount",
        "evidenceNodeCount",
        "blockerNodeCount"
      ],
      "properties": {
        "repoCount": { "type": "integer", "minimum": 0 },
        "presentRepos": { "type": "integer", "minimum": 0 },
        "missingRepos": { "type": "integer", "minimum": 0 },
        "nodeCount": { "type": "integer", "minimum": 0 },
        "edgeCount": { "type": "integer", "minimum": 0 },
        "aliasCount": { "type": "integer", "minimum": 0 },
        "configNodeCount": { "type": "integer", "minimum": 0 },
        "evidenceNodeCount": { "type": "integer", "minimum": 0 },
        "blockerNodeCount": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "nodes": {
      "type": "array",
      "items": { "$ref": "#/$defs/node" }
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "#/$defs/edge" }
    },
    "aliases": {
      "type": "array",
      "items": { "$ref": "#/$defs/alias" }
    },
    "issues": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "required": ["id", "type", "label", "repo", "source", "evidence"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "repo": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "evidence": {
          "type": "array",
          "items": { "type": "string" }
        },
        "properties": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "edge": {
      "type": "object",
      "required": ["id", "type", "source", "target", "evidence"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "target": { "type": "string", "minLength": 1 },
        "evidence": {
          "type": "array",
          "items": { "type": "string" }
        },
        "properties": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "alias": {
      "type": "object",
      "required": ["name", "path", "target"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "target": { "type": "string", "minLength": 1 },
        "mapsToRepo": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
