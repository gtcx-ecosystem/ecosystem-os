{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gtcx://ecosystem-os/kaleidoscope-ai/graph-config.schema/v1",
  "title": "Kaleidoscope AI graph config",
  "type": "object",
  "required": ["$schema", "repo", "entities", "relations", "evidencePaths", "exclude"],
  "properties": {
    "$schema": { "const": "gtcx://ecosystem-os/graph-config/v1" },
    "repo": { "type": "string", "minLength": 1 },
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "source"],
        "properties": {
          "type": { "type": "string", "minLength": 1 },
          "source": { "type": "string", "minLength": 1 }
        }
      }
    },
    "relations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "source"],
        "properties": {
          "type": { "type": "string", "minLength": 1 },
          "source": { "type": "string", "minLength": 1 }
        }
      }
    },
    "evidencePaths": { "type": "array", "items": { "type": "string" } },
    "exclude": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
