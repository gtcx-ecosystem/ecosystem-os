{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gtcx://ecosystem-os/kaleidoscope-ai/phase-3-resource-replay.schema/v1",
  "title": "Kaleidoscope AI phase 3 resource replay witness",
  "type": "object",
  "required": [
    "schema",
    "generatedAt",
    "repo",
    "phase",
    "ok",
    "summary",
    "validation",
    "contracts"
  ],
  "properties": {
    "schema": { "const": "gtcx://ecosystem-os/kaleidoscope-ai/phase-3-resource-replay/v1" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "date": { "type": "string" },
    "repo": { "const": "ecosystem-os" },
    "phase": { "const": "phase-3-resource-replay" },
    "ok": { "type": "boolean" },
    "summary": {
      "type": "object",
      "required": [
        "source",
        "sourceSha256",
        "replayBundleFingerprint",
        "resourceCount",
        "expectedResourceCount",
        "resources",
        "orderOk",
        "missingResources",
        "unexpectedResources",
        "passedResources",
        "failedResources",
        "externalUse"
      ],
      "properties": {
        "source": { "type": "string" },
        "sourceSha256": { "type": ["string", "null"] },
        "replayBundleFingerprint": { "type": "string" },
        "resourceCount": { "type": "integer", "minimum": 0 },
        "expectedResourceCount": { "type": "integer", "minimum": 0 },
        "resources": {
          "type": "array",
          "items": { "type": "string" }
        },
        "orderOk": { "type": "boolean" },
        "missingResources": {
          "type": "array",
          "items": { "type": "string" }
        },
        "unexpectedResources": {
          "type": "array",
          "items": { "type": "string" }
        },
        "passedResources": { "type": "integer", "minimum": 0 },
        "failedResources": { "type": "integer", "minimum": 0 },
        "externalUse": { "const": "blocked_until_explicit_approval" }
      },
      "additionalProperties": true
    },
    "validation": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "resource",
          "mode",
          "approval",
          "route",
          "ok",
          "issues",
          "semanticFingerprint",
          "witnesses"
        ],
        "properties": {
          "resource": { "type": "string" },
          "mode": { "enum": ["read", "draft", "write-request", "external-request"] },
          "approval": {
            "type": "object",
            "required": ["status", "boundary"],
            "properties": {
              "status": { "type": "string" },
              "boundary": { "type": "string" }
            },
            "additionalProperties": true
          },
          "route": { "type": ["string", "null"] },
          "ok": { "type": "boolean" },
          "issues": {
            "type": "array",
            "items": { "type": "string" }
          },
          "semanticFingerprint": { "type": "string" },
          "witnesses": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["path", "exists", "sha256", "bytes", "sourceDate"],
              "properties": {
                "path": { "type": "string" },
                "exists": { "type": "boolean" },
                "sha256": { "type": ["string", "null"] },
                "bytes": { "type": ["integer", "null"], "minimum": 0 },
                "sourceDate": { "type": ["string", "null"] }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    },
    "contracts": {
      "type": "object",
      "required": ["resourceReplay", "phase3Resources", "responseEnvelope"],
      "properties": {
        "resourceReplay": { "type": "string" },
        "phase3Resources": { "type": "string" },
        "responseEnvelope": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
