{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gtcx://ecosystem-os/kaleidoscope-ai/decision-room.schema/v1",
  "title": "Kaleidoscope AI decision room witness",
  "type": "object",
  "required": [
    "schema",
    "generatedAt",
    "repo",
    "phase",
    "ok",
    "summary",
    "questions",
    "issues"
  ],
  "properties": {
    "schema": { "const": "gtcx://ecosystem-os/kaleidoscope-ai/decision-room/v1" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "repo": { "const": "ecosystem-os" },
    "phase": { "type": "string", "minLength": 1 },
    "ok": { "type": "boolean" },
    "summary": {
      "type": "object",
      "required": [
        "questionCount",
        "passedQuestions",
        "failedQuestions",
        "averageConfidence",
        "unsupportedClaimWarnings",
        "staleEvidenceWarnings"
      ],
      "properties": {
        "questionCount": { "type": "integer", "minimum": 0 },
        "passedQuestions": { "type": "integer", "minimum": 0 },
        "failedQuestions": { "type": "integer", "minimum": 0 },
        "averageConfidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "unsupportedClaimWarnings": { "type": "integer", "minimum": 0 },
        "staleEvidenceWarnings": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "questions": {
      "type": "array",
      "items": { "$ref": "#/$defs/question" }
    },
    "issues": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "question": {
      "type": "object",
      "required": [
        "id",
        "question",
        "classification",
        "answer",
        "confidence",
        "citations",
        "assumptions",
        "unsupportedClaims",
        "freshness",
        "evaluation",
        "ok"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "question": { "type": "string", "minLength": 1 },
        "classification": {
          "type": "object",
          "required": ["intent", "decisionType", "route"]
        },
        "answer": {
          "type": "object",
          "required": ["headline", "rationale", "recommendedActions"]
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "citations": {
          "type": "array",
          "items": { "$ref": "#/$defs/citation" }
        },
        "assumptions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "unsupportedClaims": {
          "type": "array",
          "items": { "type": "string" }
        },
        "freshness": {
          "type": "object",
          "required": ["sourceDateCount", "oldestSourceDate", "newestSourceDate", "stale"]
        },
        "evaluation": {
          "type": "object",
          "required": ["citationGate", "freshnessGate", "unsupportedClaimGate", "confidenceGate"]
        },
        "ok": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "citation": {
      "type": "object",
      "required": ["path", "sourceDate", "reason", "excerpt"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sourceDate": { "type": ["string", "null"] },
        "reason": { "type": "string", "minLength": 1 },
        "excerpt": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
